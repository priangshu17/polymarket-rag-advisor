# ─────────────────────────────────────────────────────────────
# Polymarket RAG Advisor — API Keys
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your keys below
#   3. NEVER commit .env to Git (it's already in .gitignore)
# ─────────────────────────────────────────────────────────────

# LLM Provider: "gemini" or "groq"
LLM_PROVIDER=gemini

# Google Gemini — free at aistudio.google.com (1,500 req/day)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — free at console.groq.com (~500K tokens/day)
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search — free at tavily.com (1,000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here